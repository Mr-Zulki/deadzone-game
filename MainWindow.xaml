<Window x:Class="DEADZONE.MainWindow"
        WindowState="Maximized"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DEADZONE"
        Width="1920"
        Height="1080"
        WindowStyle="None"
        AllowsTransparency="False"
        Background="#000000"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">

    <Grid Background="#000000">

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  GAME CANVAS — fills entire window                  -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Viewbox Stretch="Uniform">
            <Canvas x:Name="GameCanvas"
            Width="1920"
            Height="1080"
            Background="Black"/>
        </Viewbox>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  TOP-LEFT HUD — PLAYER 1                            -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border x:Name="P1HudBorder"
                Width="320"
                Height="110"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="10,10,0,0"
                Padding="10,8"
                CornerRadius="10"
                Background="#CC0D1A0D"
                BorderBrush="#5BBF34"
                BorderThickness="2"
                Panel.ZIndex="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Avatar with blink overlay -->
                <Grid Width="58" VerticalAlignment="Center" Margin="0,0,6,0">
                    <Border Width="58"
                            Height="80"
                            Background="#111814"
                            BorderBrush="#8CE45A"
                            BorderThickness="1.5"
                            CornerRadius="8"
                            VerticalAlignment="Center">
                        <Image x:Name="P1AvatarImage"
                               Stretch="Uniform"
                               Margin="-2,-2,-2,0"/>
                    </Border>

                    <!-- Red blink overlay — driven by code each frame -->
                    <Border x:Name="P1AvatarBlink"
                            Width="58"
                            Height="80"
                            CornerRadius="8"
                            VerticalAlignment="Center"
                            Background="#BBFF1111"
                            Opacity="0"
                            IsHitTestVisible="False">
                        <!-- Pulsing red cross icon to signal damage -->
                        <TextBlock Text="💥"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"/>
                    </Border>
                </Grid>

                <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="PLAYER 1"
                               Foreground="#74D63F" FontSize="14" FontWeight="Bold"
                               FontFamily="Consolas"/>
                    <!-- HP Bar -->
                    <Grid Margin="0,6,0,0">
                        <Border CornerRadius="4" Background="#0A0C0D"
                                BorderBrush="#4B4F54" BorderThickness="1"/>
                        <ProgressBar x:Name="P1HealthBar" Height="24" Maximum="100" Value="100"
                                     Margin="2" Background="#0A0C0D" BorderThickness="0"
                                     Foreground="#63D22F"/>
                        <TextBlock x:Name="P1HealthText"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="White" FontSize="11" FontWeight="Bold"
                                   FontFamily="Consolas" Text="100 / 100"/>
                    </Grid>
                    <!-- Stats row -->
                    <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                        <TextBlock Text="🛡 " Foreground="#B1B7BC" FontSize="11" FontFamily="Consolas"/>
                        <TextBlock Text="0" Foreground="White" FontSize="11" FontWeight="Bold"
                                   FontFamily="Consolas"/>
                        <TextBlock Text="   💀 " Foreground="#B1B7BC" FontSize="11"
                                   FontFamily="Consolas" Margin="10,0,0,0"/>
                        <TextBlock x:Name="P1Kills" Text="0" Foreground="White"
                                   FontSize="11" FontWeight="Bold" FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  TOP-CENTER — TIMER + ZONE BANNER                   -->
        <!-- ═══════════════════════════════════════════════════ -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top"
                    Margin="0,10,0,0" Panel.ZIndex="20">
            <!-- Timer -->
            <Border Width="200" Height="62" CornerRadius="10"
                    Background="#CC101418"
                    BorderBrush="#2E353B" BorderThickness="1.5">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="🕐" FontSize="20" Foreground="White" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock x:Name="TimerText" Text="00:00"
                               Foreground="White" FontSize="28" FontWeight="Bold"
                               FontFamily="Consolas" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Kill Feed -->
            <Border x:Name="KillFeedPanel"
                    Width="340" Margin="0,8,0,0" Padding="14,10"
                    CornerRadius="8"
                    Background="#CC0B1A0B"
                    BorderBrush="#3A5C2A" BorderThickness="1.5"
                    Panel.ZIndex="20">
                <StackPanel>
                    <TextBlock Text="KILL FEED"
                               Foreground="#F0D757" FontSize="12" FontWeight="Bold"
                               FontFamily="Consolas" Margin="0,0,0,6"/>
                    <ItemsControl x:Name="KillFeedList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="#E5E8EA" FontSize="11"
                                           FontFamily="Consolas" Margin="0,2"
                                           TextWrapping="Wrap"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Zone Warning -->
            <Border x:Name="ZoneWarningBanner"
                    Margin="0,8,0,0" Padding="18,8" CornerRadius="7"
                    Background="#DD21160F" BorderBrush="#EB4D38" BorderThickness="1.5"
                    Visibility="Collapsed">
                <TextBlock Text="⚠ BLUE ZONE SHRINKING!"
                           Foreground="#FFF1E8" FontSize="15" FontWeight="Bold"
                           FontFamily="Consolas" HorizontalAlignment="Center"/>
            </Border>
        </StackPanel>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  TOP-RIGHT HUD — PLAYER 2                           -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border x:Name="P2HudBorder"
                Width="320" Height="110"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,10,10,0" Padding="10,8"
                CornerRadius="10"
                Background="#CC1A0D0D"
                BorderBrush="#D43B32" BorderThickness="2"
                Panel.ZIndex="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,10,0" VerticalAlignment="Center">
                    <TextBlock Text="PLAYER 2"
                               Foreground="#EF4F45" FontSize="14" FontWeight="Bold"
                               FontFamily="Consolas" HorizontalAlignment="Right"/>
                    <Grid Margin="0,6,0,0">
                        <Border CornerRadius="4" Background="#0A0C0D"
                                BorderBrush="#4B4F54" BorderThickness="1"/>
                        <ProgressBar x:Name="P2HealthBar" Height="24" Maximum="100" Value="100"
                                     Margin="2" Background="#0A0C0D" BorderThickness="0"
                                     Foreground="#E33D34"/>
                        <TextBlock x:Name="P2HealthText"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="White" FontSize="11" FontWeight="Bold"
                                   FontFamily="Consolas" Text="100 / 100"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                Margin="0,6,0,0">
                        <TextBlock Text="🛡 " Foreground="#B1B7BC" FontSize="11" FontFamily="Consolas"/>
                        <TextBlock Text="0" Foreground="White" FontSize="11" FontWeight="Bold"
                                   FontFamily="Consolas"/>
                        <TextBlock Text="   💀 " Foreground="#B1B7BC" FontSize="11"
                                   FontFamily="Consolas" Margin="10,0,0,0"/>
                        <TextBlock x:Name="P2Kills" Text="0" Foreground="White"
                                   FontSize="11" FontWeight="Bold" FontFamily="Consolas"/>
                    </StackPanel>
                </StackPanel>

                <!-- Avatar with blink overlay -->
                <Grid Grid.Column="1" Width="58" VerticalAlignment="Center" Margin="6,0,0,0">
                    <Border Height="80"
                            Background="#181111" BorderBrush="#F26D62"
                            BorderThickness="1.5" CornerRadius="8" VerticalAlignment="Center">
                        <Image x:Name="P2AvatarImage" Stretch="Uniform" Margin="-2,-2,-2,0"/>
                    </Border>

                    <!-- Red blink overlay for P2 -->
                    <Border x:Name="P2AvatarBlink"
                            Height="80"
                            CornerRadius="8"
                            VerticalAlignment="Center"
                            Background="#BBFF1111"
                            Opacity="0"
                            IsHitTestVisible="False">
                        <TextBlock Text="💥"
                                   FontSize="22"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="White"/>
                    </Border>
                </Grid>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  BOTTOM-LEFT — PLAYER 1 INVENTORY                   -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="10,0,0,10" Padding="12,10"
                CornerRadius="10"
                Background="#DD0B120B"
                BorderBrush="#384126" BorderThickness="1.5"
                Panel.ZIndex="20">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="WEAPONS" Foreground="#F0D757"
                               FontSize="12" FontWeight="Bold" FontFamily="Consolas"
                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="INVENTORY P1" Foreground="#A0A8B0"
                               FontSize="12" FontWeight="Bold" FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <!-- Slot 1 — Pistol -->
                    <Border x:Name="P1WeaponSlot1"
                            Width="90" Height="88" Margin="0,0,6,0" CornerRadius="7"
                            Background="#111316" BorderBrush="#F0D757" BorderThickness="2">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Margin="6,4">
                            <Image x:Name="P1Weapon1Image" Width="52" Height="30" Stretch="Uniform"/>
                            <TextBlock x:Name="P1W1Ammo" Text="12/60"
                                       Foreground="#F0F2F4" FontSize="11" FontWeight="Bold"
                                       FontFamily="Consolas" HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="1" Foreground="#F0F2F4" FontSize="11"
                                       FontFamily="Consolas" HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Slot 2 — Pickup weapon -->
                    <Border x:Name="P1WeaponSlot2"
                            Width="90" Height="88" Margin="0,0,6,0" CornerRadius="7"
                            Background="#111316" BorderBrush="#464D53" BorderThickness="1.5">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Margin="6,4">
                            <Image x:Name="P1Weapon2Image" Width="56" Height="30" Stretch="Uniform"/>
                            <TextBlock x:Name="P1W2Ammo" Text="—"
                                       Foreground="#C8CDD1" FontSize="11" FontWeight="Bold"
                                       FontFamily="Consolas" HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="2" Foreground="#F0F2F4" FontSize="11"
                                       FontFamily="Consolas" HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Slot 3 — Grenade (now functional) -->
                    <Border x:Name="P1GrenadeSlot"
                            Width="90" Height="88" CornerRadius="7"
                            Background="#111316" BorderBrush="#464D53" BorderThickness="1.5">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Margin="6,4">
                            <Image x:Name="P1Weapon4Image" Width="34" Height="34" Stretch="Uniform"/>
                            <TextBlock x:Name="P1GrenadeCount"
                                       Text="x2" Foreground="#C8CDD1" FontSize="11"
                                       FontWeight="Bold" FontFamily="Consolas"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="3" Foreground="#F0F2F4" FontSize="11"
                                       FontFamily="Consolas" HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  BOTTOM-RIGHT — PLAYER 2 INVENTORY                  -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                Margin="0,0,10,10" Padding="12,10"
                CornerRadius="10"
                Background="#DD120A0A"
                BorderBrush="#4A1A1A" BorderThickness="1.5"
                Panel.ZIndex="20">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="WEAPONS" Foreground="#F0D757"
                               FontSize="12" FontWeight="Bold" FontFamily="Consolas"
                               Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="INVENTORY P2" Foreground="#A0A8B0"
                               FontSize="12" FontWeight="Bold" FontFamily="Consolas"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <!-- Slot 1 -->
                    <Border x:Name="P2WeaponSlot1"
                            Width="90" Height="88" Margin="0,0,6,0" CornerRadius="7"
                            Background="#111316" BorderBrush="#EF4F45" BorderThickness="2">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Margin="6,4">
                            <Image x:Name="P2Weapon1Image" Width="52" Height="30" Stretch="Uniform"/>
                            <TextBlock x:Name="P2W1Ammo" Text="12/60"
                                       Foreground="#F0F2F4" FontSize="11" FontWeight="Bold"
                                       FontFamily="Consolas" HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="1" Foreground="#F0F2F4" FontSize="11"
                                       FontFamily="Consolas" HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Slot 2 -->
                    <Border x:Name="P2WeaponSlot2"
                            Width="90" Height="88" Margin="0,0,6,0" CornerRadius="7"
                            Background="#111316" BorderBrush="#464D53" BorderThickness="1.5">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Margin="6,4">
                            <Image x:Name="P2Weapon2Image" Width="56" Height="30" Stretch="Uniform"/>
                            <TextBlock x:Name="P2W2Ammo" Text="—"
                                       Foreground="#C8CDD1" FontSize="11" FontWeight="Bold"
                                       FontFamily="Consolas" HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="2" Foreground="#F0F2F4" FontSize="11"
                                       FontFamily="Consolas" HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                    <!-- Slot 3 — Grenade (now functional) -->
                    <Border x:Name="P2GrenadeSlot"
                            Width="90" Height="88" CornerRadius="7"
                            Background="#111316" BorderBrush="#464D53" BorderThickness="1.5">
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Margin="6,4">
                            <Image x:Name="P2Weapon4Image" Width="34" Height="34" Stretch="Uniform"/>
                            <TextBlock x:Name="P2GrenadeCount"
                                       Text="x2" Foreground="#C8CDD1" FontSize="11"
                                       FontWeight="Bold" FontFamily="Consolas"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="3" Foreground="#F0F2F4" FontSize="11"
                                       FontFamily="Consolas" HorizontalAlignment="Center"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  WIN SCREEN                                          -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border x:Name="WinScreen"
                Background="#CC000000"
                Visibility="Collapsed"
                Panel.ZIndex="50">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock x:Name="WinText"
                           Text="PLAYER 1 WINS!"
                           Foreground="#F0D757" FontSize="72" FontWeight="Bold"
                           FontFamily="Consolas" HorizontalAlignment="Center"/>
                <TextBlock Text="WINNER WINNER CHICKEN DINNER"
                           Foreground="White" FontSize="22" FontFamily="Consolas"
                           HorizontalAlignment="Center" Margin="0,12,0,32"/>
                <Button Content="PLAY AGAIN"
                        Width="220" Height="58"
                        Background="#67D436" Foreground="#091109"
                        FontSize="20" FontWeight="Bold" FontFamily="Consolas"
                        BorderThickness="0" Cursor="Hand"
                        Click="PlayAgain_Click"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!--  MAIN MENU OVERLAY                                  -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border x:Name="MainMenuOverlay"
                Panel.ZIndex="100"
                Visibility="Visible">
            <Grid>
                <Image Source="pack://application:,,,/Assets/menu_bg.png"
                       Stretch="UniformToFill"/>

                <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="0,40,30,0"
                        Padding="16,10"
                        BorderBrush="#AAFFFFFF"
                        BorderThickness="1"
                        Background="#55000000"
                        CornerRadius="2">
                    <StackPanel>
                        <TextBlock Text="&quot;If the enemy is in range, so are you.&quot;"
                                   Foreground="White" FontSize="14" FontFamily="Consolas"
                                   FontStyle="Italic" TextAlignment="Center"/>
                        <TextBlock Text="- Sicario 💀"
                                   Foreground="#CCFFFFFF" FontSize="12" FontFamily="Consolas"
                                   Margin="0,4,0,0" TextAlignment="Center"/>
                    </StackPanel>
                </Border>

                <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center"
                            Margin="40,80,0,0">
                    <!-- PLAY -->
                    <Border x:Name="MenuPlay"
                            Width="340" Height="72" Margin="0,0,0,8"
                            CornerRadius="0,36,36,0"
                            Background="#BB000000"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#DD1A0000"/>
                                        <Setter Property="BorderBrush" Value="#FF2200"/>
                                        <Setter Property="BorderThickness" Value="0,2,2,2"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Grid>
                            <Rectangle Width="6" HorizontalAlignment="Left" Fill="#FF2200" RadiusX="0" RadiusY="0"/>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="22,0,0,0">
                                <Border Width="38" Height="38" CornerRadius="19" Margin="0,0,16,0">
                                    <Border.Background>
                                        <SolidColorBrush Color="#EE2200"/>
                                    </Border.Background>
                                    <Border.Effect>
                                        <DropShadowEffect Color="#FF2200" BlurRadius="10" ShadowDepth="0" Opacity="0.8"/>
                                    </Border.Effect>
                                    <Viewbox Width="16" Height="16">
                                        <Canvas Width="24" Height="24">
                                            <Polygon Points="6,4 20,12 6,20" Fill="White"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <TextBlock Text="PLAY" Foreground="White" FontSize="22" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- CUSTOMIZATION -->
                    <!-- HOW TO PLAY -->
                    <Border x:Name="MenuHowTo"
        Width="340" Height="72" Margin="0,0,0,8"
        CornerRadius="0,36,36,0" Background="#88000000" BorderThickness="0" Cursor="Hand">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#CC1A0000"/>
                                        <Setter Property="BorderBrush" Value="#FF2200"/>
                                        <Setter Property="BorderThickness" Value="0,2,2,2"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="28,0,0,0">
                            <Viewbox Width="30" Height="30" Margin="0,0,16,0">
                                <Canvas Width="24" Height="24">
                                    <Ellipse Canvas.Left="7" Canvas.Top="1" Width="10" Height="10" Fill="White"/>
                                    <Path Data="M4,22 C4,16 20,16 20,22" Fill="White"/>
                                    <Ellipse Canvas.Left="15" Canvas.Top="10" Width="8" Height="8" Stroke="White" StrokeThickness="1.5" Fill="Transparent"/>
                                    <Ellipse Canvas.Left="17.5" Canvas.Top="12.5" Width="3" Height="3" Fill="White"/>
                                    <Line X1="19" Y1="11" X2="20.5" Y2="9.5" Stroke="White" StrokeThickness="1.5"/>
                                    <Line X1="19" Y1="16" X2="20.5" Y2="17.5" Stroke="White" StrokeThickness="1.5"/>
                                    <Line X1="15" Y1="14" X2="13.5" Y2="14" Stroke="White" StrokeThickness="1.5"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="HOW TO PLAY" Foreground="#DDFFFFFF" FontSize="20" FontWeight="Bold" FontFamily="Consolas" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- COMING SOON -->
                    <Border Width="340" Height="72" Margin="0,0,0,8"
        CornerRadius="0,36,36,0" Background="#55000000" BorderThickness="0" Cursor="Arrow"
        IsEnabled="False">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#66110000"/>
                                        <Setter Property="BorderBrush" Value="#993300"/>
                                        <Setter Property="BorderThickness" Value="0,2,2,2"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="28,0,0,0">
                            <Viewbox Width="30" Height="30" Margin="0,0,16,0">
                                <Canvas Width="24" Height="24">
                                    <Path Data="M12,2 A10,10 0 1,0 12,22 A10,10 0 1,0 12,2 Z M12,8 A4,4 0 1,0 12,16 A4,4 0 1,0 12,8 Z" Fill="White" Opacity="0.4"/>
                                    <Line X1="12" Y1="2" X2="12" Y2="5" Stroke="White" StrokeThickness="2.5" Opacity="0.4"/>
                                    <Line X1="12" Y1="19" X2="12" Y2="22" Stroke="White" StrokeThickness="2.5" Opacity="0.4"/>
                                    <Line X1="2" Y1="12" X2="5" Y2="12" Stroke="White" StrokeThickness="2.5" Opacity="0.4"/>
                                    <Line X1="19" Y1="12" X2="22" Y2="12" Stroke="White" StrokeThickness="2.5" Opacity="0.4"/>
                                    <Line X1="4.2" Y1="4.2" X2="6.4" Y2="6.4" Stroke="White" StrokeThickness="2.5" Opacity="0.4"/>
                                    <Line X1="17.6" Y1="17.6" X2="19.8" Y2="19.8" Stroke="White" StrokeThickness="2.5" Opacity="0.4"/>
                                    <Line X1="19.8" Y1="4.2" X2="17.6" Y2="6.4" Stroke="White" StrokeThickness="2.5" Opacity="0.4"/>
                                    <Line X1="6.4" Y1="17.6" X2="4.2" Y2="19.8" Stroke="White" StrokeThickness="2.5" Opacity="0.4"/>
                                    <!-- Lock overlay -->
                                    <Rectangle Canvas.Left="9" Canvas.Top="13" Width="6" Height="5" RadiusX="1" RadiusY="1" Fill="White" Opacity="0.7"/>
                                    <Path Data="M10,13 C10,10 14,10 14,13" Stroke="White" StrokeThickness="2" Fill="Transparent" Opacity="0.7"/>
                                </Canvas>
                            </Viewbox>
                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                <TextBlock Text="CUSTOMIZATION" Foreground="White" FontSize="20" FontWeight="Bold" FontFamily="Consolas"/>
                                <TextBlock Text="— COMING SOON —" Foreground="#99FF4400" FontSize="10" FontWeight="Bold" FontFamily="Consolas" Margin="0,-2,0,0"/>
                            </StackPanel>
