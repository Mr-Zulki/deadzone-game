                                                       Margin="0,0,0,2"/>
                                            <TextBlock Text="CHICKEN DINNER" Foreground="#888" FontSize="13"
                                                       FontFamily="Consolas" HorizontalAlignment="Center"
                                                       Margin="0,0,0,10" />
                                            <TextBlock Foreground="#707A70" FontSize="10" FontFamily="Consolas"
                                                       TextWrapping="Wrap" TextAlignment="Center"
                                                       Text="Reduce your opponent's HP to 0 to win. The game stops, the win screen appears, and you can PLAY AGAIN."/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Grid>

                        </Grid>

                        <!-- ── FOOTER NAV ────────────────────────────── -->
                        <Border Grid.Row="2"
                                Background="#AA060E06"
                                BorderBrush="#33CC1100" BorderThickness="0,1,0,0">
