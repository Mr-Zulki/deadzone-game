                                <Button x:Name="HtpPrevBtn"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Center"
                                        Width="160" Height="40"
                                        Background="#333333"
                                        Foreground="White"
                                        BorderThickness="0"
                                        FontFamily="Consolas"
                                        FontSize="14" FontWeight="Bold"
                                        Content="◄ PREVIOUS"
                                        Opacity="0.4"
                                        IsEnabled="False"/>

                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Orientation="Horizontal">
