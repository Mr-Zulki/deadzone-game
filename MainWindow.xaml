                                        Foreground="White"
                                        BorderThickness="0"
                                        FontFamily="Consolas"
                                        FontSize="14" FontWeight="Bold"
                                        Content="NEXT ►"/>
                            </Grid>
                        </Border>

                    </Grid>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
